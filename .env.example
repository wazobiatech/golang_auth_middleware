# Wazobia Tech Auth Middleware - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED: Mercury Service Configuration
# ============================================

# Base URL of the Mercury authentication service
# Example: https://mercury.yourdomain.com or http://localhost:4000
MERCURY_BASE_URL=http://localhost:4000

# Shared secret for signing JWKS requests (same as Node.js version)
# This should match the SIGNATURE_SHARED_SECRET in your Mercury service
SIGNATURE_SHARED_SECRET=your-signature-shared-secret-here

# ============================================
# REQUIRED: Redis Configuration
# ============================================

# Redis connection URL
# Format: redis://[username:password@]host:port/[db]
REDIS_URL=redis://localhost:6379

# Redis password (if required)
REDIS_PASSWORD=

# Redis database number (0-15)
REDIS_DB=0

# ============================================
# REQUIRED: Service Credentials (for service-to-service auth)
# ============================================

# Your service's client ID (from Mercury service registration)
CLIENT_ID=your-service-client-id

# Your service's client secret (from Mercury service registration)
CLIENT_SECRET=your-service-client-secret

# ============================================
# OPTIONAL: Cache Configuration
# ============================================

# Token cache expiry time in seconds (default: 3600 = 1 hour)
CACHE_EXPIRY_TIME=3600

# Service token cache TTL in seconds (default: 3300 = ~55 minutes)
# Matches Laravel config value
SERVICE_TOKEN_CACHE_TTL=3300

# Service UUID cache TTL in seconds (default: 86400 = 24 hours)
SERVICE_UUID_CACHE_TTL=86400

# JWKS cache TTL in seconds (default: 18000 = 5 hours)
JWKS_CACHE_TTL=18000

# ============================================
# OPTIONAL: Logging Configuration
# ============================================

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ============================================
# OPTIONAL: Advanced Configuration
# ============================================

# JWT signature algorithms to accept (comma-separated, default: RS512)
# SUPPORTED_ALGORITHMS=RS512

# Timeout for JWKS requests in seconds (default: 10)
HTTP_TIMEOUT=10

# Redis connection pool size (default: 10)
REDIS_POOL_SIZE=10

# Connection retry attempts (default: 3)
REDIS_MAX_RETRIES=3

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Enable debug mode for verbose logging
# DEBUG_MODE=true

# Skip certificate verification (DO NOT USE IN PRODUCTION)
# INSECURE_SKIP_VERIFY=false

# Mock Mercury service for testing
# MOCK_MERCURY=false